# ════════════════════════════════════════════
# Multi-Indicator Combo Bot — Environment Vars
# Paste these in Railway → Variables
# ════════════════════════════════════════════

# REQUIRED
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── RSI ─────────────────────────────────────
RSI_PERIOD=14
RSI_OVERSOLD=35        # Bull signal when RSI <= this
RSI_OVERBOUGHT=65      # Bear signal when RSI >= this

# ── MACD ────────────────────────────────────
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ── Bollinger Bands ──────────────────────────
BB_PERIOD=20
BB_STD=2.0

# ── EMA Cross ────────────────────────────────
EMA_FAST=9
EMA_SLOW=21

# ── Volume Spike ─────────────────────────────
VOLUME_LOOKBACK=20
VOLUME_MULTIPLIER=1.5  # Current vol >= 1.5x average = spike

# ── Scan Settings ────────────────────────────
SCAN_INTERVAL_MIN=30
MAX_CONCURRENT=40
